@model BankManagementSystem.Models.Customer
@{
    ViewData["Title"] = "Kredi Ver";
}

<h2><i class="fas fa-money-bill-wave me-2"></i>Müşteriye Kredi Ver</h2>
<hr />

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="fas fa-user me-2"></i>Müşteri Bilgileri</h5>
            </div>
            <div class="card-body">
                <p><strong>Ad Soyad:</strong> @Model.Name</p>
                <p><strong>TC Kimlik No:</strong> @Model.TC</p>
                <p><strong>Hesap Numarası:</strong> @Model.AccountNumber</p>
                <p><strong>Mevcut Bakiye:</strong> <span class="text-success fw-bold">@Model.Balance.ToString("N2") ₺</span></p>
                @if (Model.CreditLimit.HasValue)
                {
                    <p><strong>Kredi Limiti:</strong> @Model.CreditLimit.Value.ToString("N2") ₺</p>
                    <p><strong>Kullanılan Kredi:</strong> @(Model.UsedCredit?.ToString("N2") ?? "0.00") ₺</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-credit-card me-2"></i>Kredi Verme İşlemi</h5>
            </div>
            <div class="card-body">
                <form asp-action="GiveCredit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label for="creditAmount" class="form-label fw-bold">Kredi Tutarı (₺)</label>
                        <input type="number" 
                               id="creditAmount" 
                               name="creditAmount" 
                               class="form-control form-control-lg" 
                               step="0.01" 
                               min="0.01" 
                               required 
                               placeholder="0.00" />
                        <small class="form-text text-muted">Verdiğiniz kredi tutarı müşterinin hesap bakiyesine eklenecektir.</small>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Bilgi:</strong> Bu işlem sonrasında müşterinin yeni bakiyesi: 
                        <span id="newBalance" class="fw-bold text-success">@Model.Balance.ToString("N2") ₺</span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-check me-2"></i>Krediyi Onayla ve Hesaba Ekle
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Kredi tutarı girildiğinde yeni bakiyeyi hesapla
        document.getElementById('creditAmount').addEventListener('input', function() {
            var creditAmount = parseFloat(this.value) || 0;
            var currentBalance = @Model.Balance;
            var newBalance = currentBalance + creditAmount;
            
            document.getElementById('newBalance').textContent = newBalance.toFixed(2) + ' ₺';
        });
    </script>
}

