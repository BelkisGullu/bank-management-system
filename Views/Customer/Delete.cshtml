@model BankManagementSystem.Models.Customer
@{
    ViewData["Title"] = "Müşteri Sil";
}

<h2>Müşteri Sil</h2>
<h3>Bu müşteriyi silmek istediğinizden emin misiniz?</h3>
<hr />

<dl class="row">
    <dt class="col-sm-2">Müşteri No</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Ad Soyad</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">TC Kimlik No</dt>
    <dd class="col-sm-10">@Model.TC</dd>

    <dt class="col-sm-2">Şube</dt>
    <dd class="col-sm-10">@(Model.Branch?.Name ?? "N/A")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Sil</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>



