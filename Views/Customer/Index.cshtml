@model IEnumerable<BankManagementSystem.Models.Customer>
@{
    ViewData["Title"] = "Müşteriler";
}

<h2 class="mb-4"><i class="fas fa-users me-2"></i>Müşteri Yönetimi</h2>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3" id="filterForm">
            <div class="col-md-6">
                <label class="form-label fw-bold">Şubeye Göre Filtrele:</label>
                <select name="branchFilter" id="branchFilter" class="form-select" onchange="submitFormWithSearch()">
                    <option value="">Tüm Şubeler</option>
                    @if (ViewData["Branches"] is SelectList branches)
                    {
                        @foreach (var branch in branches)
                        {
                            <option value="@branch.Value" selected="@(ViewData["SelectedBranch"]?.ToString() == branch.Value)">@branch.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">İsme Göre Ara:</label>
                <div class="input-group">
                    <input type="text" name="searchName" id="searchName" class="form-control" 
                           placeholder="Müşteri adı giriniz..." 
                           value="@ViewData["SearchName"]" 
                           onkeyup="if(event.keyCode === 13) document.getElementById('filterForm').submit()">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-search me-2"></i>Ara</button>
                    @if (!string.IsNullOrEmpty(ViewData["SearchName"]?.ToString()))
                    {
                        <a asp-action="Index" asp-route-branchFilter="@ViewData["SelectedBranch"]" class="btn btn-secondary"><i class="fas fa-times me-2"></i>Temizle</a>
                    }
                </div>
            </div>
        </form>

        <script>
            function submitFormWithSearch() {
                // Şube değiştiğinde arama terimini koru
                document.getElementById('filterForm').submit();
            }
        </script>
    </div>
</div>

<a asp-action="Create" class="btn btn-success mb-3"><i class="fas fa-plus me-2"></i>Yeni Müşteri Ekle</a>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <script>
        // Toast notification göster
        setTimeout(() => {
            showToast('@TempData["SuccessMessage"]', 'success');
        }, 100);
    </script>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <script>
        setTimeout(() => {
            showToast('@TempData["ErrorMessage"]', 'danger');
        }, 100);
    </script>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-primary">
            <tr>
                <th>Müşteri No</th>
                <th>Ad Soyad</th>
                <th>TC No</th>
                <th>Telefon</th>
                <th>Email</th>
                <th>Şube</th>
                <th>Müşteri Temsilcisi</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.TC</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@(item.Branch?.Name ?? "N/A")</td>
                        <td>@(item.Representative?.Name ?? "N/A")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm"><i class="fas fa-eye me-1"></i>Detay</a>
                            <a asp-action="GiveCredit" asp-route-id="@item.Id" class="btn btn-success btn-sm"><i class="fas fa-money-bill-wave me-1"></i>Kredi Ver</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm"><i class="fas fa-edit me-1"></i>Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"><i class="fas fa-trash me-1"></i>Sil</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        @if (!string.IsNullOrEmpty(ViewData["SearchName"]?.ToString()))
                        {
                            <p><i class="fas fa-search me-2"></i>Arama kriterinize uygun müşteri bulunamadı.</p>
                        }
                        else
                        {
                            <p><i class="fas fa-inbox me-2"></i>Henüz müşteri kaydı bulunmuyor.</p>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

