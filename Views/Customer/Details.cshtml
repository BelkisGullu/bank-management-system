@model BankManagementSystem.Models.Customer
@{
    ViewData["Title"] = "Müşteri Detayları";
}

<h2>Müşteri Detayları</h2>
<hr />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<dl class="row">
    <dt class="col-sm-2">Müşteri No</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Ad Soyad</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">TC Kimlik No</dt>
    <dd class="col-sm-10">@Model.TC</dd>

    <dt class="col-sm-2">Telefon</dt>
    <dd class="col-sm-10">@Model.Phone</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>

    <dt class="col-sm-2">Şube</dt>
    <dd class="col-sm-10">@(Model.Branch?.Name ?? "N/A")</dd>

    <dt class="col-sm-2">Müşteri Temsilcisi</dt>
    <dd class="col-sm-10">@(Model.Representative?.Name ?? "N/A")</dd>

    <dt class="col-sm-2">Hesap Numarası</dt>
    <dd class="col-sm-10">@Model.AccountNumber</dd>

    <dt class="col-sm-2">Hesap Bakiyesi</dt>
    <dd class="col-sm-10">@Model.Balance.ToString("N2") TL</dd>

    <dt class="col-sm-2">Kredi Kartı No</dt>
    <dd class="col-sm-10">@(Model.CreditCard ?? "Yok")</dd>

    <dt class="col-sm-2">Kredi Limiti</dt>
    <dd class="col-sm-10">@(Model.CreditLimit?.ToString("N2") ?? "0.00") TL</dd>

    <dt class="col-sm-2">Kullanılan Kredi</dt>
    <dd class="col-sm-10">@(Model.UsedCredit?.ToString("N2") ?? "0.00") TL</dd>
</dl>

<div>
    <a asp-action="GiveCredit" asp-route-id="@Model.Id" class="btn btn-success">
        <i class="fas fa-money-bill-wave me-1"></i>Kredi Ver
    </a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
        <i class="fas fa-edit me-1"></i>Düzenle
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-1"></i>Geri Dön
    </a>
</div>



