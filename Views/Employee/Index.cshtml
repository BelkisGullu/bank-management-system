@model IEnumerable<BankManagementSystem.Models.Employee>
@{
    ViewData["Title"] = "Çalışanlar";
}

<h2 class="mb-4"><i class="fas fa-user-tie me-2"></i>Çalışan Yönetimi</h2>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3">
            <div class="col-md-10">
                <label class="form-label fw-bold">İsme Göre Ara:</label>
                <div class="input-group">
                    <input type="text" name="searchName" class="form-control" 
                           placeholder="Çalışan adı giriniz..." 
                           value="@ViewData["SearchName"]" 
                           onkeyup="if(event.keyCode === 13) this.form.submit()">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-search me-2"></i>Ara</button>
                    @if (!string.IsNullOrEmpty(ViewData["SearchName"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-times me-2"></i>Temizle</a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<a asp-action="Create" class="btn btn-success mb-3"><i class="fas fa-plus me-2"></i>Yeni Çalışan Ekle</a>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-primary">
            <tr>
                <th>Çalışan No</th>
                <th>Ad Soyad</th>
                <th>TC No</th>
                <th>Pozisyon</th>
                <th>Şube</th>
                <th>Telefon</th>
                <th>Email</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.TC</td>
                        <td>@item.Position</td>
                        <td>@(item.Branch?.Name ?? "N/A")</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm"><i class="fas fa-edit me-1"></i>Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"><i class="fas fa-trash me-1"></i>Sil</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        @if (!string.IsNullOrEmpty(ViewData["SearchName"]?.ToString()))
                        {
                            <p><i class="fas fa-search me-2"></i>Arama kriterinize uygun çalışan bulunamadı.</p>
                        }
                        else
                        {
                            <p><i class="fas fa-inbox me-2"></i>Henüz çalışan kaydı bulunmuyor.</p>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>



