@model BankManagementSystem.Models.ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";
}

<h2>Mesaj Detayı</h2>
<hr />

<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Ad Soyad</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>

    <dt class="col-sm-2">Telefon</dt>
    <dd class="col-sm-10">@(Model.Phone ?? "-")</dd>

    <dt class="col-sm-2">Konu</dt>
    <dd class="col-sm-10">@Model.Subject</dd>

    <dt class="col-sm-2">Mesaj</dt>
    <dd class="col-sm-10">
        <div class="border p-3 bg-light">
            @Model.Message
        </div>
    </dd>

    <dt class="col-sm-2">Müşteri</dt>
    <dd class="col-sm-10">@(Model.Customer?.Name ?? "-")</dd>

    <dt class="col-sm-2">Tarih</dt>
    <dd class="col-sm-10">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>

    <dt class="col-sm-2">Durum</dt>
    <dd class="col-sm-10">
        @if (Model.IsRead)
        {
            <span class="badge bg-success">Okundu</span>
        }
        else
        {
            <span class="badge bg-warning">Okunmadı</span>
        }
    </dd>
</dl>

<div>
    <a asp-action="Messages" class="btn btn-secondary">Geri Dön</a>
</div>



