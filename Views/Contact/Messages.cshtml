@model IEnumerable<BankManagementSystem.Models.ContactMessage>
@{
    ViewData["Title"] = "İletişim Mesajları";
}

<h2 class="mb-4">📧 İletişim Mesajları</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-primary">
            <tr>
                <th>ID</th>
                <th>Ad Soyad</th>
                <th>Email</th>
                <th>Konu</th>
                <th>Tarih</th>
                <th>Müşteri</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var message in Model)
            {
                <tr class="@(message.IsRead ? "" : "table-warning")">
                    <td>@message.Id</td>
                    <td>@message.Name</td>
                    <td>@message.Email</td>
                    <td>@message.Subject</td>
                    <td>@message.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(message.Customer?.Name ?? "-")</td>
                    <td>
                        @if (message.IsRead)
                        {
                            <span class="badge bg-success">Okundu</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Okunmadı</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@message.Id" class="btn btn-info btn-sm">Detay</a>
                        @if (!message.IsRead)
                        {
                            <form asp-action="MarkAsRead" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@message.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Okundu İşaretle</button>
                            </form>
                        }
                        <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Mesajı silmek istediğinizden emin misiniz?');">
                            <input type="hidden" name="id" value="@message.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>



