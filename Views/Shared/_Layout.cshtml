<!DOCTYPE html>
<html lang="tr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Banka Yönetim Sistemi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BankManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3 bank-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <i class="fas fa-university me-2"></i>Banka Yönetim Sistemi
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        var userType = Context.Session.GetString("UserType");
                        var userId = Context.Session.GetString("UserId");
                        var customerId = Context.Session.GetString("CustomerId");
                    }
                    @if (!string.IsNullOrEmpty(userId) || !string.IsNullOrEmpty(customerId))
                    {
                        @if (userType == "Admin")
                        {
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                        <i class="fas fa-home me-1"></i>Ana Sayfa
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Customer" asp-action="Index">
                                        <i class="fas fa-users me-1"></i>Müşteriler
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Employee" asp-action="Index">
                                        <i class="fas fa-user-tie me-1"></i>Çalışanlar
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Branch" asp-action="Index">
                                        <i class="fas fa-building me-1"></i>Şubeler
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Contact" asp-action="Messages">
                                        <i class="fas fa-envelope me-1"></i>İletişim Mesajları
                                    </a>
                                </li>
                            </ul>
                        }
                        else if (userType == "Customer")
                        {
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="CustomerDashboard" asp-action="Index">
                                        <i class="fas fa-home me-1"></i>Ana Sayfa
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="CustomerDashboard" asp-action="Profile">
                                        <i class="fas fa-user me-1"></i>Profilim
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Contact" asp-action="Index">
                                        <i class="fas fa-envelope me-1"></i>Bize Ulaşın
                                    </a>
                                </li>
                            </ul>
                        }
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <button id="themeToggle" class="btn btn-outline-light me-2" type="button">
                                    <i id="themeIcon" class="fas fa-moon"></i>
                                </button>
                            </li>
                            @if (userType == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Contact" asp-action="Index">
                                        <i class="fas fa-envelope me-1"></i>Bize Ulaşın
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-1"></i>Çıkış
                                </a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <button id="themeToggle" class="btn btn-outline-light me-2" type="button">
                                    <i id="themeIcon" class="fas fa-moon"></i>
                                </button>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="loginDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-sign-in-alt me-1"></i>Giriş Yap
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="loginDropdown">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Login"><i class="fas fa-user-shield me-2"></i>Yönetici Girişi</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="CustomerLogin"><i class="fas fa-user me-2"></i>Müşteri Girişi</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="registerDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-plus me-1"></i>Kayıt Ol
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="registerDropdown">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Register"><i class="fas fa-user-shield me-2"></i>Yönetici Kayıt</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="CustomerRegister"><i class="fas fa-user me-2"></i>Müşteri Kayıt</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Contact" asp-action="Index">
                                    <i class="fas fa-envelope me-1"></i>Bize Ulaşın
                                </a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; 2025 - Banka Yönetim Sistemi - <a asp-controller="Contact" asp-action="Index">Bize Ulaşın</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="~/js/animations.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
