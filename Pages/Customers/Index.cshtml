@page
@model BankManagementSystem.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Müşteriler (Razor Pages)";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4"><i class="fas fa-users me-2"></i>Müşteriler - Razor Pages</h2>
            
            @if (Model.Customers != null && Model.Customers.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th>ID</th>
                                <th>Ad Soyad</th>
                                <th>TC Kimlik No</th>
                                <th>Email</th>
                                <th>Bakiye</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in Model.Customers)
                            {
                                <tr>
                                    <td>@customer.Id</td>
                                    <td>@customer.Name</td>
                                    <td>@customer.TC</td>
                                    <td>@customer.Email</td>
                                    <td>@customer.Balance.ToString("N2") ₺</td>
                                    <td>
                                        <a asp-page="./Details" asp-route-id="@customer.Id" class="btn btn-info btn-sm">
                                            <i class="fas fa-eye me-1"></i>Detay
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>Henüz müşteri kaydı bulunmuyor.
                </div>
            }
        </div>
    </div>
</div>



